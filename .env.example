# Supabase Dashboard > Project Settings > API.
# The publishable key is safe for browser use because database access is protected by RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Required for temporary registration and recovery without email.
# Never prefix this value with NEXT_PUBLIC_ or expose it in browser code.
SUPABASE_SECRET_KEY=

# Keep false to pause signup-confirmation and password-reset emails.
# Set true and rebuild when Supabase email delivery is available again.
NEXT_PUBLIC_EMAIL_SERVICES_ENABLED="false"

# Automatically sign out authenticated users after this many inactive minutes.
NEXT_PUBLIC_SESSION_IDLE_TIMEOUT_MINUTES="30"