# Supabase target.
# Local example: NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Remote example: NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_* variables are exposed to browser code. Never put service role
# keys, database passwords, JWT secrets, or full database URLs in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe public key only.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only service role or secret key. Required for temporary registration
# and recovery without email. Never prefix this value with NEXT_PUBLIC_ or expose
# it in browser code.
SUPABASE_SECRET_KEY=

# Keep false to pause signup-confirmation and password-reset emails.
# Set true and rebuild when Supabase email delivery is available again.
NEXT_PUBLIC_EMAIL_SERVICES_ENABLED=false

# Automatically sign out authenticated users after this many inactive minutes.
NEXT_PUBLIC_SESSION_IDLE_TIMEOUT_MINUTES=30
