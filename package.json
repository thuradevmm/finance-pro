{
  "name": "finance-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/clean-next-dev-types.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "db:login": "npx supabase login",
    "db:link": "npx supabase link",
    "db:status": "npx supabase status",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:new": "npx supabase migration new",
    "db:diff": "npx supabase db diff",
    "db:pull": "npx supabase db pull",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:migration:list": "npx supabase migration list",
    "db:types": "npx supabase gen types typescript --linked --schema public > src/types/database.ts",
    "db:types:local": "npx supabase gen types typescript --local --schema public > src/types/database.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "next": "^16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "supabase": "^2.107.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
