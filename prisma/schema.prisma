generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

model accounts {
  id                                                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                                 String           @db.Uuid
  name                                                    String
  type                                                    String           @default("cash")
  currency_code                                           String           @default("MMK") @db.VarChar(3)
  initial_balance                                         Decimal          @default(0) @db.Decimal(14, 2)
  description                                             String?
  color                                                   String?
  icon                                                    String?
  is_active                                               Boolean          @default(true)
  sort_order                                              Int              @default(0)
  metadata                                                Json             @default("{}")
  created_at                                              DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                                              DateTime         @default(now()) @db.Timestamptz(6)
  deleted_at                                              DateTime?        @db.Timestamptz(6)
  user_profiles                                           user_profiles    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assets                                                  assets[]
  debts                                                   debts[]
  savings_goals                                           savings_goals[]
  scenario_items                                          scenario_items[]
  subscriptions                                           subscriptions[]
  transactions_transactions_account_idToaccounts          transactions[]   @relation("transactions_account_idToaccounts")
  transactions_transactions_transfer_account_idToaccounts transactions[]   @relation("transactions_transfer_account_idToaccounts")
  user_settings                                           user_settings[]

  @@index([is_active], map: "idx_accounts_active")
  @@index([type], map: "idx_accounts_type")
  @@index([user_id, deleted_at], map: "idx_accounts_user_deleted")
  @@index([user_id], map: "idx_accounts_user_id")
}

model asset_history_events {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  asset_id       String        @db.Uuid
  user_id        String        @db.Uuid
  event_type     String
  event_date     DateTime      @default(dbgenerated("CURRENT_DATE")) @db.Date
  amount         Decimal?      @db.Decimal(14, 2)
  title          String?
  description    String?
  transaction_id String?       @db.Uuid
  metadata       Json          @default("{}")
  created_at     DateTime      @default(now()) @db.Timestamptz(6)
  assets         assets        @relation(fields: [asset_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions   transactions? @relation(fields: [transaction_id], references: [id], onUpdate: NoAction)
  user_profiles  user_profiles @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([asset_id, event_date(sort: Desc)], map: "idx_asset_history_asset_date")
  @@index([transaction_id], map: "idx_asset_history_transaction")
  @@index([user_id, event_type], map: "idx_asset_history_user_type")
}

model assets {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String                 @db.Uuid
  name                 String
  asset_category       String?
  purchase_date        DateTime?              @db.Date
  purchase_amount      Decimal?               @db.Decimal(14, 2)
  account_id           String?                @db.Uuid
  transaction_id       String?                @db.Uuid
  status               String                 @default("owned")
  description          String?
  metadata             Json                   @default("{}")
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  deleted_at           DateTime?              @db.Timestamptz(6)
  asset_history_events asset_history_events[]
  accounts             accounts?              @relation(fields: [account_id], references: [id], onUpdate: NoAction)
  transactions         transactions?          @relation(fields: [transaction_id], references: [id], onUpdate: NoAction)
  user_profiles        user_profiles          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([asset_category], map: "idx_assets_category")
  @@index([user_id, deleted_at], map: "idx_assets_deleted")
  @@index([transaction_id], map: "idx_assets_transaction")
  @@index([user_id], map: "idx_assets_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model budget_items {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budget_plan_id   String       @db.Uuid
  category_id      String?      @db.Uuid
  type             String       @default("expense")
  planned_amount   Decimal      @db.Decimal(14, 2)
  alert_percentage Decimal?     @default(80) @db.Decimal(5, 2)
  note             String?
  metadata         Json         @default("{}")
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime     @default(now()) @db.Timestamptz(6)
  budget_plans     budget_plans @relation(fields: [budget_plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  categories       categories?  @relation(fields: [category_id], references: [id], onUpdate: NoAction)

  @@index([category_id], map: "idx_budget_items_category")
  @@index([budget_plan_id], map: "idx_budget_items_plan")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model budget_plans {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String         @db.Uuid
  name          String
  plan_type     String         @default("budget")
  period_type   String         @default("monthly")
  start_date    DateTime       @db.Date
  end_date      DateTime       @db.Date
  status        String         @default("active")
  description   String?
  metadata      Json           @default("{}")
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime       @default(now()) @db.Timestamptz(6)
  deleted_at    DateTime?      @db.Timestamptz(6)
  budget_items  budget_items[]
  user_profiles user_profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, plan_type, status], map: "idx_budget_plans_type_status")
  @@index([user_id, start_date, end_date], map: "idx_budget_plans_user_period")
}

model categories {
  id                                                                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                                             String?          @db.Uuid
  name                                                                String
  type                                                                String
  parent_id                                                           String?          @db.Uuid
  icon                                                                String?
  color                                                               String?
  is_default                                                          Boolean          @default(false)
  is_active                                                           Boolean          @default(true)
  sort_order                                                          Int              @default(0)
  metadata                                                            Json             @default("{}")
  created_at                                                          DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                                                          DateTime         @default(now()) @db.Timestamptz(6)
  deleted_at                                                          DateTime?        @db.Timestamptz(6)
  budget_items                                                        budget_items[]
  categories                                                          categories?      @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_categories                                                    categories[]     @relation("categoriesTocategories")
  user_profiles                                                       user_profiles?   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  debts                                                               debts[]
  scenario_items                                                      scenario_items[]
  subscriptions                                                       subscriptions[]
  transactions                                                        transactions[]
  user_settings_user_settings_default_expense_category_idTocategories user_settings[]  @relation("user_settings_default_expense_category_idTocategories")
  user_settings_user_settings_default_income_category_idTocategories  user_settings[]  @relation("user_settings_default_income_category_idTocategories")

  @@unique([user_id, name, type], map: "unique_category_per_user")
  @@index([parent_id], map: "idx_categories_parent")
  @@index([user_id, deleted_at], map: "idx_categories_user_deleted")
  @@index([user_id, type], map: "idx_categories_user_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
