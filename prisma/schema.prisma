  categories             categories[]
  debts                  debts[]
  export_jobs            export_jobs[]
  file_links             file_links[]
  financial_scenarios    financial_scenarios[]
  people                 people[]
  person_payment_records person_payment_records[]
  savings_goals          savings_goals[]
  subscriptions          subscriptions[]
  transactions           transactions[]
  uploaded_files         uploaded_files[]
  user_settings          user_settings?
}

model user_settings {
  user_id                                                          String        @id @db.Uuid
  currency_code                                                    String        @default("MMK") @db.VarChar(3)
  date_format                                                      String        @default("DD/MM/YYYY")
  default_account_id                                               String?       @db.Uuid
  default_income_category_id                                       String?       @db.Uuid
  default_expense_category_id                                      String?       @db.Uuid
  settings                                                         Json          @default("{}")
  created_at                                                       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at                                                       DateTime      @default(now()) @db.Timestamptz(6)
  accounts                                                         accounts?     @relation(fields: [default_account_id], references: [id], onUpdate: NoAction)
  categories_user_settings_default_expense_category_idTocategories categories?   @relation("user_settings_default_expense_category_idTocategories", fields: [default_expense_category_id], references: [id], onUpdate: NoAction)
  categories_user_settings_default_income_category_idTocategories  categories?   @relation("user_settings_default_income_category_idTocategories", fields: [default_income_category_id], references: [id], onUpdate: NoAction)
  user_profiles                                                    user_profiles @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

