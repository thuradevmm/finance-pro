}

model export_jobs {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String        @db.Uuid
  export_type   String
  file_format   String
  status        String        @default("pending")
  file_url      String?
  filter        Json          @default("{}")
  error_message String?
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  completed_at  DateTime?     @db.Timestamptz(6)
  user_profiles user_profiles @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, status], map: "idx_export_jobs_user_status")
}

model file_links {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String         @db.Uuid
  file_id        String         @db.Uuid
  entity_type    String
  entity_id      String         @db.Uuid
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  uploaded_files uploaded_files @relation(fields: [file_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_profiles  user_profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([file_id, entity_type, entity_id], map: "unique_file_entity_link")
  @@index([entity_type, entity_id], map: "idx_file_links_entity")
  @@index([user_id], map: "idx_file_links_user")
}

